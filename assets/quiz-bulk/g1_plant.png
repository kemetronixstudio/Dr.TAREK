<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <rect x="120" y="180" width="60" height="50" rx="5" fill="#8d6e63"/>
  <line x1="150" y1="180" x2="150" y2="80" stroke="#4caf50" stroke-width="6"/>
  <ellipse cx="110" cy="110" rx="40" ry="25" fill="#4caf50" transform="rotate(-30 110 110)"/>
  <ellipse cx="190" cy="120" rx="40" ry="25" fill="#4caf50" transform="rotate(30 190 120)"/>
  <ellipse cx="150" cy="80" rx="35" ry="20" fill="#66bb6a"/>
  <circle cx="220" cy="60" r="30" fill="#ffd600" opacity="0.9"/>
  <line x1="220" y1="25" x2="220" y2="10" stroke="#ffd600" stroke-width="3"/>
  <line x1="245" y1="35" x2="255" y2="25" stroke="#ffd600" stroke-width="3"/>
  <text x="150" y="245" text-anchor="middle" font-size="14" font-family="Arial" font-weight="bold" fill="#555">Plants need Sunlight</text>

</svg>