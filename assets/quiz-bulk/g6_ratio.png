<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <text x="150" y="100" text-anchor="middle" font-size="24" font-family="Arial" fill="#555">15 : 25</text>
  <line x1="80" y1="115" x2="220" y2="115" stroke="#555" stroke-width="2"/>
  <text x="150" y="135" text-anchor="middle" font-size="18" font-family="Arial" fill="#555">÷5 : ÷5</text>
  <text x="150" y="185" text-anchor="middle" font-size="34" font-family="Arial" font-weight="bold" fill="#4caf50">3 : 5</text>
  <text x="150" y="243" text-anchor="middle" font-size="14" font-family="Arial" font-weight="bold" fill="#555">Simplest Ratio</text>

</svg>