<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <line x1="30" y1="125" x2="270" y2="125" stroke="#555" stroke-width="3"/>
  <text x="40" y="115" font-size="13" font-family="Arial" fill="#555">-8</text>
  <text x="72" y="115" font-size="13" font-family="Arial" fill="#555">-6</text>
  <text x="104" y="115" font-size="13" font-family="Arial" fill="#555">-4</text>
  <text x="136" y="115" font-size="13" font-family="Arial" fill="#555">-2</text>
  <text x="165" y="115" font-size="13" font-family="Arial" fill="#555">0</text>
  <text x="195" y="115" font-size="13" font-family="Arial" fill="#555">2</text>
  <circle cx="50" cy="125" r="8" fill="#e63946"/>
  <circle cx="170" cy="125" r="8" fill="#1a73e8"/>
  <text x="150" y="175" text-anchor="middle" font-size="22" font-family="Arial" font-weight="bold" fill="#e63946">-3+(-5) = -8</text>
  <text x="150" y="243" text-anchor="middle" font-size="14" font-family="Arial" font-weight="bold" fill="#555">Integer Addition</text>

