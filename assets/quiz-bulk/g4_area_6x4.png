<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <rect x="65" y="80" width="170" height="112" fill="#4285f4" opacity="0.25" stroke="#4285f4" stroke-width="4"/>
  <text x="150" y="148" text-anchor="middle" font-size="22" font-family="Arial" font-weight="bold" fill="#1a73e8">6 × 4</text>
  <text x="150" y="78" text-anchor="middle" font-size="13" font-family="Arial" fill="#555">6 units</text>
  <text x="47" y="145" font-size="13" font-family="Arial" fill="#555" transform="rotate(-90 47 145)">4 units</text>
  <text x="150" y="235" text-anchor="middle" font-size="15" font-family="Arial" font-weight="bold" fill="#555">Area = 24 sq units</text>

</svg>