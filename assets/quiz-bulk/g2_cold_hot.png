  <rect x="160" y="70" width="110" height="120" rx="15" fill="#e63946" opacity="0.8"/>
  <text x="215" y="140" text-anchor="middle" font-size="28" font-family="Arial" font-weight="bold" fill="white">☀ Hot</text>
  <text x="150" y="243" text-anchor="middle" font-size="14" font-family="Arial" font-weight="bold" fill="#555">Opposites</text>

