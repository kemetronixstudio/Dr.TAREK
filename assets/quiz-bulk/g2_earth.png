<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <circle cx="150" cy="125" r="90" fill="#1a73e8"/>
  <ellipse cx="130" cy="90" rx="40" ry="35" fill="#4caf50" transform="rotate(-20 130 90)"/>
  <ellipse cx="175" cy="130" rx="35" ry="45" fill="#4caf50" transform="rotate(10 175 130)"/>
  <ellipse cx="110" cy="155" rx="25" ry="20" fill="#4caf50"/>
  <ellipse cx="150" cy="125" rx="90" ry="90" fill="none" stroke="#0d47a1" stroke-width="3"/>
  <text x="150" y="240" text-anchor="middle" font-size="16" font-family="Arial" font-weight="bold" fill="#555">Planet Earth</text>

</svg>