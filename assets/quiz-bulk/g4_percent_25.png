<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <rect x="55" y="70" width="190" height="130" rx="10" fill="#e8f5e9" stroke="#4caf50" stroke-width="3"/>
  <rect x="55" y="70" width="47" height="130" rx="10" fill="#4caf50" opacity="0.9"/>
  <text x="75" y="145" text-anchor="middle" font-size="18" font-family="Arial" fill="white" font-weight="bold">25%</text>
  <text x="190" y="145" text-anchor="middle" font-size="18" font-family="Arial" fill="#4caf50">75%</text>
  <text x="150" y="243" text-anchor="middle" font-size="14" font-family="Arial" font-weight="bold" fill="#555">25% of 200 = 50</text>

</svg>