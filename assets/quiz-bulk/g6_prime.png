<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <text x="150" y="100" text-anchor="middle" font-size="16" font-family="Arial" fill="#555">Primes: <tspan font-weight="bold" fill="#e63946">2</tspan>, 3, 5, 7, 11...</text>
  <text x="150" y="148" text-anchor="middle" font-size="65" font-family="Arial" font-weight="bold" fill="#e63946">2</text>
  <text x="150" y="207" text-anchor="middle" font-size="16" font-family="Arial" fill="#555">Smallest Prime Number</text>
  <text x="150" y="243" text-anchor="middle" font-size="13" font-family="Arial" font-weight="bold" fill="#555">Divisible only by 1 and itself</text>

</svg>