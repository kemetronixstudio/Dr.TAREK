<svg xmlns="http://www.w3.org/2000/svg" width="300" height="250" viewBox="0 0 300 250">
  <rect width="300" height="250" fill="#fff8f0" rx="20"/>
  
  <text x="150" y="90" text-anchor="middle" font-size="18" font-family="Arial" fill="#555">4 + 8 + 6 + 10 = 28</text>
  <line x1="60" y1="105" x2="240" y2="105" stroke="#555" stroke-width="2"/>
  <text x="150" y="130" text-anchor="middle" font-size="18" font-family="Arial" fill="#555">          4</text>
  <text x="150" y="175" text-anchor="middle" font-size="34" font-family="Arial" font-weight="bold" fill="#1a73e8">Mean = 7</text>
  <text x="150" y="243" text-anchor="middle" font-size="14" font-family="Arial" font-weight="bold" fill="#555">Statistics — Mean</text>

</svg>